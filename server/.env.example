# RetroArr Server Configuration
# Copy this to .env and fill in your values

# HTTP server port (HDHomeRun convention: 5004 or 8888)
PORT=8888

# Your VPS API base URL — no /api suffix (routes are at root: /videos, /health, etc.)
REMOTE_API_URL=https://retroarr-api.f00d.me

# Friendly name shown in Plex/Jellyfin
DEVICE_NAME=RetroArr

# Stream output quality: 720p or 1080p
STREAM_QUALITY=720p

# Number of simultaneous tuner streams
TUNER_COUNT=4

# Paths to FFmpeg and yt-dlp binaries (defaults work in Docker)
FFMPEG_PATH=ffmpeg
YTDLP_PATH=yt-dlp

# Path to local database JSON file
DB_PATH=./db/db.json

# How often to refresh from remote API (hours)
CACHE_REFRESH_HOURS=24

# Timezone for cron jobs
TZ=America/New_York