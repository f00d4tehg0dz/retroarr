# Dependencies
node_modules/
**/node_modules/

# Environment variables (contain API keys)
.env
**/.env

# Local database (user-specific, generated at runtime)
server/db/db.json
server/db/

# React build output (generated by npm run build)
server/public/

# Commercial videos (user-provided, not committed)
server/data/commercials/*.mp4
server/data/commercials/*.mkv
server/data/commercials/*.avi
server/data/commercials/*.ts
server/data/commercials/*.mov
server/data/commercials/*.wmv

# API server .env (contains API keys + Mongo credentials)
api-server/.env

# Scripts .env (inherits from api-server)
scripts/.env

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

.history
/history